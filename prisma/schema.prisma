generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Educator {
  id            String   @id
  name          String
  email         String   @unique
  role          String   // "educatrice" | "admin" | "cuisiniere" | "entretien" | "secretaire"
  seniorityRank Int?
  isQualified   Boolean?
  passwordHash  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model VacationRequest {
  id              String    @id @default(cuid())
  educatorId      String
  educatorName    String
  startDate       DateTime
  endDate        DateTime
  reason          String?
  status          String    // "pending" | "accepted" | "rejected"
  rejectionReason String?
  createdAt       DateTime  @default(now())
  reviewedAt      DateTime?
}

model VacationRulesConfig {
  id        String   @id @default("default")
  rules     String   // JSON stringifié
  updatedAt DateTime @updatedAt
}
