generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Educator {
  id            String   @id
  name          String
  email         String   @unique
  role          String   // "educatrice" | "admin" | "cuisiniere" | "entretien" | "secretaire"
  seniorityRank Int?
  isQualified   Boolean?
  passwordHash  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model VacationRequest {
  id                  String    @id @default(cuid())
  educatorId          String
  educatorName        String
  startDate           DateTime
  endDate             DateTime
  reason              String?
  status              String    // "pending" | "accepted" | "rejected" | "cancelled"
  rejectionReason     String?
  urgentAppealReason  String?   // Raison d'urgence soumise par l'éducatrice
  appealReviewedAt    DateTime? // Quand l'admin a traité l'appel
  legacyImport        Boolean   @default(false) // Pré-plateforme (affichage) ; inclus dans les calculs de règles comme tout congé accepté
  createdAt           DateTime  @default(now())
  reviewedAt          DateTime?
  cancelledAt         DateTime?
  cancellationPendingAt DateTime? // Employé : demande d’annulation après échéance (en attente admin)
  adminCancellationReason String? @db.Text // Message admin à l’employé lors de l’annulation d’un congé accepté
}

model VacationRulesConfig {
  id        String   @id @default("default")
  rules     String   // JSON stringifié
  updatedAt DateTime @updatedAt
}

// Déclaration d'absence maladie (sans workflow congés)
model SickLeaveReport {
  id               String   @id @default(cuid())
  educatorId       String
  educatorName     String
  startDate        DateTime
  endDate          DateTime
  note             String?
  attachmentBase64 String?  @db.Text
  attachmentMime   String?
  attachmentName   String?
  // Employé a coché « je n'ai pas de document à fournir » (obligatoire si pas de fichier)
  declaredNoAttachment Boolean @default(false)
  createdAt        DateTime @default(now())
}

// Demande d’échange de journée de congé hebdomadaire entre éducatrices
model DayOffSwapRequest {
  id                  String    @id @default(cuid())
  requesterId         String
  requesterName       String
  requesterIsQualified Boolean  @default(false)
  requesterOffDay     Int       // 1 = lundi … 7 = dimanche (ISO, getISODay)
  mode                String    // "open" | "targeted"
  targetEducatorId    String?
  targetEducatorName  String?

  status              String    // "pending" | "confirmed" | "cancelled"
  acceptedById        String?
  acceptedByName      String?
  counterpartyOffDay  Int?      // jour de congé de la collègue qui accepte
  acceptedAt          DateTime?

  message             String?   @db.Text

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([status])
  @@index([requesterId])
  @@index([targetEducatorId])
}

// Journal technique : qui a soumis quoi, depuis quelle IP / navigateur (traçabilité interne)
model ActivityAuditLog {
  id           String   @id @default(cuid())
  educatorId   String
  educatorName String
  action       String
  resourceType String
  resourceId   String?
  detail       String?  @db.Text
  ip           String?
  userAgent    String?  @db.Text
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([educatorId])
}
