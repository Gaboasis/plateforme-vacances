# Base de données PostgreSQL (Railway, Neon, Supabase, Postgres local, etc.)
# L’URL doit commencer par postgresql:// ou postgres://
# Souvent : ajoutez ?sslmode=require à la fin pour les hébergeurs cloud.
# Copiez ce fichier en .env puis remplacez USER, PASSWORD, HOST par vos vraies valeurs.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/nom_base?sslmode=require"
