# Base de données PostgreSQL (Railway ou Neon)
# Railway : copiez l’URL « public / connect from anywhere » depuis le service PostgreSQL.
# Depuis votre Mac, le proxy public exige souvent TLS : ajoutez ?sslmode=require à la fin
# (directUrl = même URL si vous n’avez qu’un seul endpoint public).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/railway?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/railway?sslmode=require"
